# Backend URLs — use localhost so the browser (running on the host) can reach the API.
# In production, point these at your deployed Render/Railway API URL.

# ─── Local dev (default) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Remote dev (share app with someone on another device/network) ───────────
# Requires 3 terminals: `make dev`, `make tunnel-ngrok`, `make tunnel-cloudflare`
# Open the ngrok URL in a browser — do NOT open the cloudflared URL directly.
#
# NEXT_PUBLIC_API_URL=https://<cloudflared-url-from-tunnel-cloudflare>
# NEXT_PUBLIC_WS_URL=wss://<cloudflared-url-from-tunnel-cloudflare>
#
# cloudflared assigns a new URL every restart — update these and re-run `make dev`.
# Also add your ngrok frontend URL to apps/api/.env → CORS_ORIGINS (no trailing slash).
