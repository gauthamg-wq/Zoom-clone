DATABASE_URL=sqlite:///./data/zoom.db
DEFAULT_USER_ID=1
PORT=8000

# Comma-separated list of allowed browser origins (the page URL, not the API URL).
# Production: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Base URL of the Next.js frontend — used to build invite links stored in the DB.
# Production (no trailing slash):
# FRONTEND_URL=https://zoom-clone-web-brown.vercel.app

# ─── Local dev (default) ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Remote dev (with ngrok frontend + cloudflared API) ──────────────────────
# Add your ngrok URL — the origin where users open the app in a browser.
# Do NOT add the cloudflared URL here. No trailing slashes.
#
# CORS_ORIGINS=http://localhost:3000,https://your-subdomain.ngrok-free.dev
