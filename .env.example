# Root .env.example — aggregated reference for all environment variables.
# Each app also has its own .env.example with the same variables.
# Copy the relevant section to apps/web/.env.local or apps/api/.env.

# ─── apps/web ────────────────────────────────────────────────────────────────
# Browser-facing URLs. Must use localhost in local dev (not Docker service names).
# In production, point at your Render API URL (https/wss).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── apps/api ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/zoom.db
# Comma-separated list of allowed CORS origins.
# Production: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000
DEFAULT_USER_ID=1
PORT=8000
