# Root .env.example — aggregated reference for all environment variables.
# Each app also has its own .env.example with the same variables.
# Copy the relevant section to apps/web/.env.local or apps/api/.env.

# ─── apps/web ────────────────────────────────────────────────────────────────
# Browser-facing URLs. Must use localhost in local dev (not Docker service names).
# In production, point at your Render API URL (https/wss).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Remote dev: run `make tunnel` for setup. Point these at the cloudflared URL:
# NEXT_PUBLIC_API_URL=https://<cloudflared-url>
# NEXT_PUBLIC_WS_URL=wss://<cloudflared-url>

# ─── apps/api ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/zoom.db
# Comma-separated browser origins (frontend URL, not API URL). No trailing slashes.
# Production: CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# Remote dev: add your ngrok frontend URL:
# CORS_ORIGINS=http://localhost:3000,https://your-subdomain.ngrok-free.dev
DEFAULT_USER_ID=1
PORT=8000
